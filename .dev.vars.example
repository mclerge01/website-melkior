# Copy this file to .dev.vars and fill in the values.
# .dev.vars is gitignored. Never commit secrets.

# GitHub OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_SESSION_SECRET=

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# Contact form
CONTACT_EMAIL=
CONTACT_DESTINATION=consultation@melkiorclerge.ca

# Instagram Graph API
# Requires an Instagram professional account connected to Meta developer access.
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_GRAPH_VERSION=v23.0
INSTAGRAM_MEDIA_LIMIT=6
INSTAGRAM_CACHE_TTL=0
