# Copy this file to .dev.vars and fill in the values.
# .dev.vars is gitignored. Never commit secrets.

# GitHub OAuth App
# Use your local development GitHub OAuth App client ID.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_SESSION_SECRET=
ADMIN_COOKIE_SECURE=false
ADMIN_PUBLIC_ORIGIN=http://127.0.0.1:8788

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# Contact form
# Private final recipient mailbox. Do not use the public contact alias here.
CONTACT_DESTINATION=
EMAIL_FAILURE_WEBHOOK_URL=
